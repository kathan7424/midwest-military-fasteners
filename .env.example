# WordPress REST API
NEXT_PUBLIC_WP_API=https://dev-mmf-wp.pantheonsite.io/wp-json

# WooCommerce REST API
NEXT_PUBLIC_WC_API=https://dev-mmf-wp.pantheonsite.io/wp-json/wc/v3

# Site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Shared secret sent as the X-MMF-Proxy header on server-side WP requests
# (server-only — never expose with a NEXT_PUBLIC prefix). Set the same value
# on the WordPress side so it can verify the header.
MMF_PROXY_SECRET=
